{
  "name": "voxaflow",
  "version": "0.1.0",
  "private": true,
  "description": "VoxaFlow monorepo",
  "workspaces": [
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run --workspaces --if-present build",
    "lint": "npm run --workspaces --if-present lint",
    "test": "npm run --workspaces --if-present test",
    "typecheck": "npm run --workspaces --if-present typecheck",
    "demo:e2e": "bash ./scripts/simulate_call.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.7.4",
    "eslint": "^9.12.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.1",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "zod": "^4.4.3"
  }
}
